# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=3000
NODE_ENV=development

# ========================================
# FIREBASE ADMIN SDK
# Get these from: Firebase Console → Project Settings → Service Accounts
# Click "Generate New Private Key" - choose Node.js
# ========================================
FIREBASE_PROJECT_ID=your-project-id-here
FIREBASE_PRIVATE_KEY_ID=your-private-key-id-here
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-service-account-email@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id-here
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account-email%40your-project.iam.gserviceaccount.com

# ========================================
# REALTIME DATABASE & STORAGE
# Get these from Firebase Console
# ========================================
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# ========================================
# JWT AUTHENTICATION (create any random string)
# ========================================
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=7d

# ========================================
# EMAIL NOTIFICATIONS (for Gmail)
# ========================================
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# ========================================
# CORS (for web and mobile apps)
# ========================================
WEB_APP_URL=http://localhost:3000
MOBILE_APP_URL=http://localhost:19006
